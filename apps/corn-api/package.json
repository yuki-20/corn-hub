{
  "name": "@corn/corn-api",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx tsc && node -e \"require('fs').cpSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "start": "node dist/index.js",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@corn/shared-mem9": "workspace:*",
    "@corn/shared-types": "workspace:*",
    "@corn/shared-utils": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "hono": "^4.7.0",
    "sql.js": "^1.12.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.10",
    "tsx": "^4.19.0"
  }
}
