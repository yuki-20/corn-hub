# ─── ScalpelMCP Environment Configuration ──────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── General ─────────────────────────────────────────────
NODE_ENV=development

# ─── Voyage AI / OpenAI (for embeddings) ─────────────
# Set base to https://api.voyageai.com/v1 for Voyage
OPENAI_API_BASE=https://api.voyageai.com/v1
OPENAI_API_KEY=pa-...
MEM9_EMBEDDING_MODEL=voyage-code-3
MEM9_EMBEDDING_DIMS=1024
# ─── Gemini (optional, for LLM gateway) ──────────────────
GEMINI_API_KEY=

# ─── MCP API Keys (one per agent) ────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SCALPEL_API_KEY_DEFAULT=

# ─── Dashboard ───────────────────────────────────────────
DASHBOARD_PORT=3000

# ─── Service URLs ────────────────────────────────────────
QDRANT_URL=http://localhost:6333
DATABASE_PATH=./data/scalpel.db
